<div class="bg-card border border-border rounded-xl">
    {% block table %}
        {% if pagination is not null and pagination is not empty %}
            <div>
                <table class="min-w-full">
                    {% block table_header %}
                        {% if tableColumns is defined %}
                            <thead>
                            <tr class="border-b border-border bg-muted/30">
                                {% for column in tableColumns %}
                                    {% if loop.first %}
                                        {% set textPosition = 'text-left' %}
                                    {% elseif loop.last %}
                                        {% set textPosition = 'text-right' %}
                                    {% else %}
                                        {% set textPosition = 'text-center' %}
                                    {% endif %}
                                    <th scope="col" class="px-6 py-3 {{ textPosition }} whitespace-nowrap">
                                        <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground [&_a]:text-muted-foreground [&_a:hover]:text-foreground [&_a]:no-underline">{{ column|raw }}</span>
                                    </th>
                                {% endfor %}
                            </tr>
                            </thead>
                        {% endif %}
                    {% endblock %}

                    {% block table_items %}
                        <tbody class="divide-y divide-border">
                        {% for item in pagination %}
                            {% block table_item %}{% endblock %}
                        {% endfor %}
                        </tbody>
                    {% endblock %}
                </table>
            </div>
        {% endif %}
    {% endblock %}
</div>
