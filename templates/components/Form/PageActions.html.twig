{# @prop formId The id of the form element to target (default: 'main-form') #}
{# @prop cancelLink Optional URL — renders cancel as <a> instead of type="reset" #}
{# @prop cancelLabel Override label for the cancel button (default: 'reset'|trans) #}
{# @prop saveLabel Override label for the save button (default: 'save_changes'|trans) #}
{%- props formId = 'main-form', cancelLink = null, cancelLabel = null, saveLabel = null -%}

{%- if cancelLink is not null -%}
    <twig:SFUIToolbox:Generic:Button variant="ghost" link="{{ cancelLink }}">
        {{- cancelLabel ?? 'reset'|trans -}}
    </twig:SFUIToolbox:Generic:Button>
{%- else -%}
    <twig:SFUIToolbox:Generic:Button variant="ghost" type="reset" form="{{ formId }}">
        {{- cancelLabel ?? 'reset'|trans -}}
    </twig:SFUIToolbox:Generic:Button>
{%- endif -%}

<twig:SFUIToolbox:Generic:Button type="submit" form="{{ formId }}">
    {{- saveLabel ?? 'save_changes'|trans -}}
</twig:SFUIToolbox:Generic:Button>
