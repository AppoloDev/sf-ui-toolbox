{# @prop title Section title #}
{# @prop description Section description (optional) #}
{# @prop icon Lucide icon name (optional) #}
{# @prop has_filters Whether to show a filter toggle button alongside the search bar #}
{# @block filters Filter fields shown in the collapsible panel (only when has_filters=true) #}
{# @block content The list/grid content #}
{% props title = '', description = '', icon = '', has_filters = false %}
<section class="flex-grow min-w-0 space-y-6">

    {% if title %}
        <twig:SFUIToolbox:Generic:SectionHeader icon="{{ icon }}" title="{{ title }}" description="{{ description }}"/>
    {% endif %}

    {% if has_filters %}
        {# ── SearchBar card with filter toggle ───────────────────── #}
        <div data-controller="filter-panel" class="space-y-2">
            <div class="bg-card rounded-xl p-1.5 flex items-center border border-border gap-1">
                <form class="flex-1 flex items-center px-2.5 gap-2 min-w-0">
                    <span class="text-muted-foreground shrink-0">
                        <twig:ux:icon name="iconoir:search" class="size-4"/>
                    </span>
                    <input
                        name="q"
                        value="{{ app.request.query.get('q') }}"
                        placeholder="{{ 'search_placeholder'|trans }}"
                        class="flex-1 min-w-0 bg-transparent text-sm text-foreground placeholder:text-muted-foreground outline-none border-none focus:ring-0"
                        type="text"
                    />
                    {% set _routeParams = app.request.attributes.get('_route_params') is not empty ? app.request.attributes.get('_route_params') : {} %}
                    <twig:SFUIToolbox:Generic:Button class="p-0 bg-transparent !text-primary hover:bg-transparent" link="{{ path(app.request.attributes.get('_route'), _routeParams) }}">
                        <twig:ux:icon name="iconoir:xmark"/>
                    </twig:SFUIToolbox:Generic:Button>
                    <twig:SFUIToolbox:Generic:Button class="py-2" type="submit">
                        {{ 'filter'|trans }}
                    </twig:SFUIToolbox:Generic:Button>
                </form>
                <div class="w-px h-6 bg-border shrink-0"></div>
                <twig:SFUIToolbox:Generic:Button
                    variant="ghost" size="icon" type="button"
                    class="data-[active]:bg-primary/10 data-[active]:text-primary shrink-0"
                    data-action="click->filter-panel#toggle"
                    data-filter-panel-target="toggle"
                >
                    <twig:ux:icon name="lucide:sliders-horizontal" class="size-4"/>
                </twig:SFUIToolbox:Generic:Button>
            </div>

            <div class="hidden bg-card border border-border rounded-xl p-4" data-filter-panel-target="panel">
                {% block filters %}{% endblock %}
            </div>
        </div>
    {% else %}
        <twig:SFUIToolbox:Generic:SearchBar/>
    {% endif %}

    {% block content %}{% endblock %}

</section>
