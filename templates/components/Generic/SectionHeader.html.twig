{% props icon = '', title = '', description = '', class = '' %}
<div class="flex items-center gap-3 {{ class }}">
    {% if icon %}
        <div class="size-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <twig:ux:icon name="{{ icon }}" class="size-5 text-primary"/>
        </div>
    {% endif %}
    <div>
        <h2 class="text-2xl font-bold text-foreground">{{ title }}</h2>
        {% if description %}<p class="text-muted-foreground">{{ description }}</p>{% endif %}
    </div>
</div>
