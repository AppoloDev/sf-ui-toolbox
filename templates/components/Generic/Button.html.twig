{# @prop variant 'solid'|'outline'|'ghost'|'link' The shape variant, default to `solid` #}
{# @prop intent 'default'|'destructive'|'secondary' The color intent, default to `default` #}
{# @prop size 'default'|'sm'|'lg'|'icon'|'icon-sm'|'icon-lg' The size, default to `default` #}
{# @prop as 'button' The HTML tag to use, default to `button` #}
{# @prop link Optional URL shorthand — renders as <a> tag with href #}
{# @prop allowDisplay Whether to display the button, default to `true` #}
{# @block content The button label and/or icon #}
{%- props variant = 'solid', intent = 'default', size = 'default', as = 'button', link = null, allowDisplay = true -%}

{# Backward compat aliases for old variant names #}
{%- if variant == 'default' -%}{%- set variant = 'solid' -%}{%- endif -%}
{%- if variant == 'destructive' -%}{%- set intent = 'destructive' -%}{%- set variant = 'solid' -%}{%- endif -%}
{%- if variant == 'secondary' -%}{%- set intent = 'secondary' -%}{%- set variant = 'solid' -%}{%- endif -%}

{%- if link is not null -%}{%- set as = 'a' -%}{%- endif -%}

{# Color classes indexed by variant × intent #}
{%- set _colors = {
    solid: {
        default:     'bg-primary text-primary-foreground hover:bg-primary/90',
        destructive: 'bg-destructive text-white hover:bg-destructive/90 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/60',
        secondary:   'bg-secondary text-secondary-foreground hover:bg-secondary/80',
    },
    outline: {
        default:     'border bg-background hover:bg-accent hover:text-accent-foreground dark:bg-input/30 dark:border-input dark:hover:bg-input/50',
        destructive: 'border border-destructive text-destructive bg-background hover:bg-destructive hover:text-white',
        secondary:   'border border-secondary text-secondary-foreground bg-background hover:bg-secondary/10',
    },
    ghost: {
        default:     'hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50',
        destructive: 'text-destructive hover:bg-destructive/10',
        secondary:   'text-secondary-foreground hover:bg-secondary/20',
    },
    link: {
        default:     'text-primary underline-offset-4 hover:underline',
        destructive: 'text-destructive underline-offset-4 hover:underline',
        secondary:   'text-secondary-foreground underline-offset-4 hover:underline',
    },
} -%}

{%- set _colorClass = (_colors[variant] is defined and _colors[variant][intent] is defined) ? _colors[variant][intent] : _colors['solid']['default'] -%}

{%- set style = html_cva(
    base: "cursor-pointer inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive",
    variants: {
        size: {
            default:   'h-9 px-4 py-2 has-[>svg]:px-3',
            sm:        'h-8 rounded-md gap-1.5 px-3 has-[>svg]:px-2.5',
            lg:        'h-10 rounded-md px-6 has-[>svg]:px-4',
            icon:      'size-9',
            'icon-sm': 'size-8',
            'icon-lg': 'size-10',
        },
    },
) -%}

{%- if allowDisplay is same as(true) -%}
<{{ as }}
    data-slot="button"
    class="{{ style.apply({size: size}, _colorClass ~ ' ' ~ attributes.render('class'))|tailwind_merge }}"
    {% if link is not null %}href="{{ link }}"{% endif %}
    {{ attributes }}
>
    {%- block content %}{% endblock -%}
</{{ as }}>
{%- endif -%}
