{% props pagination, route, item_label = 'élément' %}
{% if pagination is not null and pagination is not empty %}
    <div class="flex items-center justify-between pt-4 pb-12">
        <p class="text-sm text-muted-foreground">
            {{ 'showing_x_of_y_items'|trans({'%count%': pagination.count, '%total%': pagination.totalItemCount, '%item%': item_label ~ (pagination.totalItemCount > 1 ? 's' : '')}) }}
        </p>
        {% if pagination.pageCount > 1 %}
            <div class="flex gap-3">
                {% if pagination.currentPageNumber > 1 %}
                    <twig:SFUIToolbox:Generic:Button variant="outline" link="{{ path(route, app.request.query.all()|merge({page: pagination.currentPageNumber - 1})) }}">
                        <twig:ux:icon name="lucide:chevron-left" class="size-4"/>
                        {{ 'previous'|trans }}
                    </twig:SFUIToolbox:Generic:Button>
                {% else %}
                    <span class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg border border-border bg-muted text-muted-foreground opacity-50 cursor-not-allowed">
                        <twig:ux:icon name="lucide:chevron-left" class="size-4"/>
                        {{ 'previous'|trans }}
                    </span>
                {% endif %}
                {% if pagination.currentPageNumber < pagination.pageCount %}
                    <twig:SFUIToolbox:Generic:Button variant="outline" link="{{ path(route, app.request.query.all()|merge({page: pagination.currentPageNumber + 1})) }}">
                        {{ 'next'|trans }}
                        <twig:ux:icon name="lucide:chevron-right" class="size-4"/>
                    </twig:SFUIToolbox:Generic:Button>
                {% else %}
                    <span class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg border border-border bg-muted text-muted-foreground opacity-50 cursor-not-allowed">
                        {{ 'next'|trans }}
                        <twig:ux:icon name="lucide:chevron-right" class="size-4"/>
                    </span>
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endif %}
